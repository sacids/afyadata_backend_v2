GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

#AFYADATA HUB
AFYADATA_HUB_URL=https://hub.afyadata.sacids.org/api/v1/projects/register/
AFYADATA_HUB_API_KEY=get-key-from-hub
